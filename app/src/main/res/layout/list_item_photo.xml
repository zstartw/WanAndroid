<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="clickListener"
            type="android.view.View.OnClickListener"/>
        <variable
            name="photo"
            type="com.betterzw.wanandroid.bean.HomeListItem"/>
    </data>

    <!--<com.google.samples.apps.sunflower.views.MaskedCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/card_side_margin"
        android:layout_marginEnd="@dimen/card_side_margin"
        android:layout_marginBottom="@dimen/card_bottom_margin"
        android:onClick="@{clickListener}"
        app:cardElevation="@dimen/card_elevation"
        app:cardPreventCornerOverlap="false"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Sunflower.Card">-->

            <androidx.constraintlayout.widget.ConstraintLayout
                android:onClick="@{clickListener}"
                android:layout_width="match_parent"
                android:padding="12dp"
                android:layout_height="wrap_content">

                <!--<ImageView
                    android:id="@+id/plant_photo"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/plant_item_image_height"
                    android:contentDescription="@string/a11y_plant_item_image"
                    android:scaleType="centerCrop"
                    app:imageFromUrl="@{photo.urls.small}"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />-->

                <TextView
                    android:id="@+id/post_title_tv"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@{photo.title}"
                    android:textSize="@dimen/text_size_medium"
                    android:textAppearance="?attr/textAppearanceListItem"
                    android:textColor="@color/black_main"
                    android:gravity="left"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:text="Sunny F."/>


                <TextView
                    android:id="@+id/post_date_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:textSize="@dimen/text_size_tiny"
                    android:textColor="@color/grey_main"
                    android:text="@{photo.niceDate}"
                    tools:text="2020-01-28" />

                <TextView
                    android:id="@+id/post_author_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@{photo.author}"
                    android:layout_marginTop="10dp"
                    app:layout_constraintTop_toBottomOf="@+id/post_title_tv"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:textSize="@dimen/text_size_tiny"
                    android:textColor="@color/black_main"
                    tools:text="作者"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

   <!-- </com.google.samples.apps.sunflower.views.MaskedCardView>-->

</layout>
